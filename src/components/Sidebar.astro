---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cities = ['Quito', 'Guayaquil', 'Cuenca', 'Virtual'];
const categories = ['Eventos', 'Formación', 'Competencias', 'Emprendimiento', 'Financiamiento', 'Comunidad', 'Empleo'];

// Subcategorías / Temas
const topics = [
  'Conferencias', 'Congresos', 'Charlas', 'Meetups', 'Workshops', 'Seminarios', 'Ferias Tecnológicas', 'Ferias Empresariales', 'Networking', 'Webinars',
  'Cursos', 'Bootcamps', 'Diplomados', 'Certificaciones', 'Talleres', 'Programas de Capacitación',
  'Hackathons', 'Concursos', 'Olimpiadas', 'Competencias de IA', 'Competencias de Ciencia de Datos', 'Competencias de Programación',
  'Convocatorias', 'Incubadoras', 'Aceleradoras', 'Startup Programs', 'Demo Days', 'Pitch Competitions',
  'Becas', 'Grants', 'Fondos de Innovación', 'Capital Semilla', 'Fondos de Investigación',
  'Mentorías', 'Comunidades Tech', 'User Groups', 'Capítulos IEEE', 'Google Developer Groups', 'Women Techmakers',
  'Ferias de Empleo', 'Recruiting Events', 'Career Days', 'Tech Recruiting', 'IA', 'Cloud', 'Startups', 'Ecuador'
];

// Orígenes (Fuentes)
const sources = [
  'Eventbrite', 'Luma', 'Devpost', 'MLH', 'Coursera', 'edX', 'AWS', 'Google Cloud', 
  'Azure', 'OpenAI', 'HuggingFace', 'Startup Grind', 'Techstars', 'Fulbright', 'EPN', 'ESPOL'
];

const modalities = [
  { label: t('sidebar.modality.inPerson'), value: 'presential' },
  { label: t('sidebar.modality.virtual'), value: 'virtual' }
];
const costs = [
  { label: t('sidebar.cost.free'), value: 'free' },
  { label: t('sidebar.cost.paid'), value: 'paid' }
];
const dates = [
  { label: t('sidebar.date.thisMonth'), value: 'this-month' },
  { label: t('sidebar.date.nextMonth'), value: 'next-month' },
  { label: t('sidebar.date.next3Months'), value: 'next-3-months' }
];
---

<aside class="w-full lg:w-72 flex-shrink-0 lg:sticky lg:top-36 z-10 lg:max-h-[calc(100vh-9rem)] overflow-y-auto custom-scrollbar rounded-2xl">
  
  <div class="bg-[var(--card-bg)] border border-[var(--border-color)] rounded-2xl p-6 backdrop-blur-sm shadow-lg shadow-[var(--color-sim-primary)]/5 transition-colors duration-300">
    <div class="flex items-center justify-between mb-4 sticky top-0 bg-[var(--card-bg)] z-10 py-2">
      <h2 class="text-lg font-bold text-[var(--text-color)] flex items-center gap-2 transition-colors duration-300">
        <svg class="w-5 h-5 text-[var(--color-sim-action)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"></path></svg>
        {t('sidebar.filters')}
      </h2>
      <button id="clear-filters" class="text-xs text-[var(--color-sim-orange)] hover:text-orange-500 transition-colors font-semibold hidden">
        {t('sidebar.clear')}
      </button>
    </div>

    <!-- Filtro de Categorías -->
    <details class="group mb-4" open>
      <summary class="flex justify-between items-center font-semibold text-gray-700 dark:text-gray-300 cursor-pointer list-none select-none">
        <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">{t('sidebar.category')}</span>
        <svg class="w-4 h-4 transition-transform group-open:rotate-180 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </summary>
      <div class="space-y-2 mt-3 pl-1">
        {categories.map(category => (
          <label class="flex items-center gap-3 cursor-pointer group/item">
            <div class="relative flex items-center">
              <input type="checkbox" class="peer sr-only filter-input" name="category" value={category} />
              <div class="w-5 h-5 border border-gray-300 dark:border-[var(--border-color)] rounded bg-white dark:bg-gray-800 peer-checked:bg-[var(--color-sim-action)] peer-checked:border-[var(--color-sim-action)] transition-colors"></div>
              <svg class="absolute w-3.5 h-3.5 text-white left-0.5 top-0.5 opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover/item:text-[var(--color-sim-action)] transition-colors">{category}</span>
          </label>
        ))}
      </div>
    </details>

    <hr class="border-neutral-200 dark:border-neutral-800 my-4" />

    <!-- Filtro de Proveedores (Sources) -->
    <details class="group mb-4">
      <summary class="flex justify-between items-center font-semibold text-gray-700 dark:text-gray-300 cursor-pointer list-none select-none">
        <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">Plataformas</span>
        <svg class="w-4 h-4 transition-transform group-open:rotate-180 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </summary>
      <div class="space-y-2 mt-3 pl-1 max-h-48 overflow-y-auto custom-scrollbar">
        {sources.map(source => (
          <label class="flex items-center gap-3 cursor-pointer group/item">
            <div class="relative flex items-center">
              <input type="checkbox" class="peer sr-only filter-input" name="source" value={source} />
              <div class="w-5 h-5 border border-gray-300 dark:border-[var(--border-color)] rounded bg-white dark:bg-gray-800 peer-checked:bg-[var(--color-sim-action)] peer-checked:border-[var(--color-sim-action)] transition-colors"></div>
              <svg class="absolute w-3.5 h-3.5 text-white left-0.5 top-0.5 opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover/item:text-[var(--color-sim-action)] transition-colors">{source}</span>
          </label>
        ))}
      </div>
    </details>

    <hr class="border-neutral-200 dark:border-neutral-800 my-4" />

    <!-- Filtro de Temas (Topics) -->
    <details class="group mb-4">
      <summary class="flex justify-between items-center font-semibold text-gray-700 dark:text-gray-300 cursor-pointer list-none select-none">
        <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">Temáticas</span>
        <svg class="w-4 h-4 transition-transform group-open:rotate-180 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </summary>
      <div class="space-y-2 mt-3 pl-1 max-h-48 overflow-y-auto custom-scrollbar">
        {topics.map(topic => (
          <label class="flex items-center gap-3 cursor-pointer group/item">
            <div class="relative flex items-center">
              <input type="checkbox" class="peer sr-only filter-input" name="topic" value={topic} />
              <div class="w-5 h-5 border border-gray-300 dark:border-[var(--border-color)] rounded bg-white dark:bg-gray-800 peer-checked:bg-[var(--color-sim-action)] peer-checked:border-[var(--color-sim-action)] transition-colors"></div>
              <svg class="absolute w-3.5 h-3.5 text-white left-0.5 top-0.5 opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover/item:text-[var(--color-sim-action)] transition-colors">{topic}</span>
          </label>
        ))}
      </div>
    </details>

    <hr class="border-neutral-200 dark:border-neutral-800 my-4" />

    <!-- Filtro de Fecha -->
    <details class="group mb-4" open>
      <summary class="flex justify-between items-center font-semibold text-gray-700 dark:text-gray-300 cursor-pointer list-none select-none">
        <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">{t('sidebar.date')}</span>
        <svg class="w-4 h-4 transition-transform group-open:rotate-180 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </summary>
      <div class="space-y-2 mt-3 pl-1">
        {dates.map(date => (
          <label class="flex items-center gap-3 cursor-pointer group/item">
            <div class="relative flex items-center">
              <input type="radio" class="peer sr-only filter-input" name="date" value={date.value} />
              <div class="w-5 h-5 border border-gray-300 dark:border-[var(--border-color)] rounded-full bg-white dark:bg-gray-800 peer-checked:bg-[var(--color-sim-action)] peer-checked:border-[var(--color-sim-action)] transition-colors"></div>
              <div class="absolute w-2 h-2 bg-white rounded-full left-1.5 top-1.5 opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity"></div>
            </div>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover/item:text-[var(--color-sim-action)] transition-colors">{date.label}</span>
          </label>
        ))}
      </div>
    </details>

    <hr class="border-neutral-200 dark:border-neutral-800 my-4" />

    <!-- Filtro de Modalidad -->
    <details class="group mb-4" open>
      <summary class="flex justify-between items-center font-semibold text-gray-700 dark:text-gray-300 cursor-pointer list-none select-none">
        <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">{t('sidebar.modality')}</span>
        <svg class="w-4 h-4 transition-transform group-open:rotate-180 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </summary>
      <div class="space-y-2 mt-3 pl-1">
        {modalities.map(mod => (
          <label class="flex items-center gap-3 cursor-pointer group/item">
            <div class="relative flex items-center">
              <input type="checkbox" class="peer sr-only filter-input" name="modality" value={mod.value} />
              <div class="w-5 h-5 border border-gray-300 dark:border-[var(--border-color)] rounded bg-white dark:bg-gray-800 peer-checked:bg-[var(--color-sim-action)] peer-checked:border-[var(--color-sim-action)] transition-colors"></div>
              <svg class="absolute w-3.5 h-3.5 text-white left-0.5 top-0.5 opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover/item:text-[var(--color-sim-action)] transition-colors">{mod.label}</span>
          </label>
        ))}
      </div>
    </details>

    <hr class="border-neutral-200 dark:border-neutral-800 my-4" />

    <!-- Filtro de Costo -->
    <details class="group mb-4" open>
      <summary class="flex justify-between items-center font-semibold text-gray-700 dark:text-gray-300 cursor-pointer list-none select-none">
        <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">{t('sidebar.cost')}</span>
        <svg class="w-4 h-4 transition-transform group-open:rotate-180 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </summary>
      <div class="space-y-2 mt-3 pl-1">
        {costs.map(cost => (
          <label class="flex items-center gap-3 cursor-pointer group/item">
            <div class="relative flex items-center">
              <input type="checkbox" class="peer sr-only filter-input" name="cost" value={cost.value} />
              <div class="w-5 h-5 border border-gray-300 dark:border-[var(--border-color)] rounded bg-white dark:bg-gray-800 peer-checked:bg-[var(--color-sim-action)] peer-checked:border-[var(--color-sim-action)] transition-colors"></div>
              <svg class="absolute w-3.5 h-3.5 text-white left-0.5 top-0.5 opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover/item:text-[var(--color-sim-action)] transition-colors">{cost.label}</span>
          </label>
        ))}
      </div>
    </details>

    <hr class="border-neutral-200 dark:border-neutral-800 my-4" />

    <!-- Filtro de Ciudad -->
    <details class="group mb-2">
      <summary class="flex justify-between items-center font-semibold text-gray-700 dark:text-gray-300 cursor-pointer list-none select-none">
        <span class="text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400">{t('sidebar.location')}</span>
        <svg class="w-4 h-4 transition-transform group-open:rotate-180 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
      </summary>
      <div class="space-y-2 mt-3 pl-1">
        {cities.map(city => (
          <label class="flex items-center gap-3 cursor-pointer group/item">
            <div class="relative flex items-center">
              <input type="checkbox" class="peer sr-only filter-input" name="city" value={city} />
              <div class="w-5 h-5 border border-gray-300 dark:border-[var(--border-color)] rounded bg-white dark:bg-gray-800 peer-checked:bg-[var(--color-sim-action)] peer-checked:border-[var(--color-sim-action)] transition-colors"></div>
              <svg class="absolute w-3.5 h-3.5 text-white left-0.5 top-0.5 opacity-0 peer-checked:opacity-100 pointer-events-none transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
            </div>
            <span class="text-sm font-medium text-gray-700 dark:text-gray-300 group-hover/item:text-[var(--color-sim-action)] transition-colors">{city}</span>
          </label>
        ))}
      </div>
    </details>

  </div>
</aside>

<style>
  /* Ocultar el marcador nativo del details en navegadores webkit */
  details > summary::-webkit-details-marker {
    display: none;
  }
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(156, 163, 175, 0.3);
    border-radius: 4px;
  }
</style>

<script>
  // Filter Logic
  document.addEventListener('DOMContentLoaded', () => {
    const inputs = document.querySelectorAll('.filter-input') as NodeListOf<HTMLInputElement>;
    const clearBtn = document.getElementById('clear-filters');
    
    // Pagination State
    let currentPage = 1;
    let pageSizeSelect = document.getElementById('page-size') as HTMLSelectElement;
    let itemsPerPage = parseInt(pageSizeSelect?.value || '24', 10);
    
    const prevBtn = document.getElementById('prev-page') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-page') as HTMLButtonElement;
    const pageNumbersContainer = document.getElementById('page-numbers');
    const paginationContainer = document.getElementById('pagination-container');
    
    function applyFilters(resetPage = false) {
      if (resetPage) currentPage = 1;
      
      const selectedCities = Array.from(document.querySelectorAll('input[name="city"]:checked')).map(el => (el as HTMLInputElement).value);
      const selectedCategories = Array.from(document.querySelectorAll('input[name="category"]:checked')).map(el => (el as HTMLInputElement).value);
      const selectedSources = Array.from(document.querySelectorAll('input[name="source"]:checked')).map(el => (el as HTMLInputElement).value);
      const selectedTopics = Array.from(document.querySelectorAll('input[name="topic"]:checked')).map(el => (el as HTMLInputElement).value);
      const selectedModalities = Array.from(document.querySelectorAll('input[name="modality"]:checked')).map(el => (el as HTMLInputElement).value);
      const selectedCosts = Array.from(document.querySelectorAll('input[name="cost"]:checked')).map(el => (el as HTMLInputElement).value);
      
      const dateFilterEl = document.querySelector('input[name="date"]:checked') as HTMLInputElement;
      const selectedDate = dateFilterEl ? dateFilterEl.value : null;

      const searchInput = document.getElementById('global-search') as HTMLInputElement;
      const searchVal = searchInput ? searchInput.value.toLowerCase().trim() : '';
      const clearSearchBtn = document.getElementById('clear-search');

      if (clearSearchBtn) {
        if (searchVal.length > 0) clearSearchBtn.classList.remove('hidden');
        else clearSearchBtn.classList.add('hidden');
      }

      const hasFilters = selectedCities.length || selectedCategories.length || selectedSources.length || selectedTopics.length || selectedModalities.length || selectedCosts.length || selectedDate || searchVal.length > 0;
      if (clearBtn) {
        if (hasFilters) clearBtn.classList.remove('hidden');
        else clearBtn.classList.add('hidden');
      }

      const wrappers = document.querySelectorAll('.event-wrapper') as NodeListOf<HTMLElement>;
      let filteredElements: HTMLElement[] = [];

      const now = new Date();
      const currentMonth = now.getMonth();
      const currentYear = now.getFullYear();

      wrappers.forEach(wrapper => {
        const city = wrapper.dataset.city || '';
        const category = wrapper.dataset.category || '';
        const source = wrapper.dataset.source || '';
        const searchableText = (wrapper.dataset.search || '').toLowerCase();
        
        const modality = wrapper.dataset.modality || '';
        const cost = wrapper.dataset.cost || '';
        const timestamp = parseInt(wrapper.dataset.date || '0', 10);
        const eventDate = new Date(timestamp);
        
        let matchCity = selectedCities.length === 0 || selectedCities.includes(city) || (city === 'Virtual' && selectedCities.includes('Virtual'));
        let matchCategory = selectedCategories.length === 0 || selectedCategories.includes(category);
        
        let matchSource = selectedSources.length === 0 || selectedSources.some(s => source.includes(s) || searchableText.includes(s.toLowerCase()));
        let matchTopic = selectedTopics.length === 0 || selectedTopics.some(t => searchableText.includes(t.toLowerCase()));

        let matchModality = selectedModalities.length === 0 || selectedModalities.includes(modality);
        let matchCost = selectedCosts.length === 0 || selectedCosts.includes(cost);
        
        let matchDate = true;
        if (selectedDate === 'this-month') {
          matchDate = eventDate.getMonth() === currentMonth && eventDate.getFullYear() === currentYear;
        } else if (selectedDate === 'next-month') {
          const nextMonth = (currentMonth + 1) % 12;
          const targetYear = nextMonth === 0 ? currentYear + 1 : currentYear;
          matchDate = eventDate.getMonth() === nextMonth && eventDate.getFullYear() === targetYear;
        } else if (selectedDate === 'next-3-months') {
          const threeMonthsFromNow = new Date(now);
          threeMonthsFromNow.setMonth(now.getMonth() + 3);
          matchDate = eventDate >= now && eventDate <= threeMonthsFromNow;
        }

        const matchSearch = searchVal === '' || searchableText.includes(searchVal);

        if (matchCity && matchCategory && matchSource && matchTopic && matchModality && matchCost && matchDate && matchSearch) {
          filteredElements.push(wrapper);
        } else {
          wrapper.style.display = 'none';
          wrapper.style.opacity = '0';
          wrapper.style.transform = 'scale(0.95)';
        }
      });
      
      const totalItems = filteredElements.length;
      const totalPages = Math.max(1, Math.ceil(totalItems / itemsPerPage));
      
      // Asegurar que currentPage no exceda el máximo
      if (currentPage > totalPages) currentPage = totalPages;
      
      const startIndex = (currentPage - 1) * itemsPerPage;
      const endIndex = Math.min(startIndex + itemsPerPage, totalItems);
      
      // Mostrar solo los elementos de la página actual
      filteredElements.forEach((wrapper, index) => {
        if (index >= startIndex && index < endIndex) {
          if (wrapper.style.display === 'none') {
             wrapper.style.display = 'block';
             requestAnimationFrame(() => {
               wrapper.style.opacity = '1';
               wrapper.style.transform = 'scale(1)';
             });
          }
        } else {
          wrapper.style.display = 'none';
          wrapper.style.opacity = '0';
          wrapper.style.transform = 'scale(0.95)';
        }
      });

      // Update Pagination UI
      if (paginationContainer) {
        paginationContainer.style.display = totalItems > 0 ? 'flex' : 'none';
      }
      
      if (prevBtn && nextBtn && pageNumbersContainer) {
        prevBtn.disabled = currentPage === 1;
        nextBtn.disabled = currentPage === totalPages;
        
        pageNumbersContainer.innerHTML = '';
        
        // Mostrar hasta 5 números de página para no romper el layout
        let startPage = Math.max(1, currentPage - 2);
        let endPage = Math.min(totalPages, startPage + 4);
        
        if (endPage - startPage < 4) {
          startPage = Math.max(1, endPage - 4);
        }
        
        for (let i = startPage; i <= endPage; i++) {
          const btn = document.createElement('button');
          btn.textContent = i.toString();
          btn.className = `px-3 py-1 rounded-md text-sm font-medium transition-colors ${i === currentPage ? 'bg-[var(--color-sim-action)] text-white' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800'}`;
          btn.onclick = () => {
            currentPage = i;
            applyFilters(false);
            window.scrollTo({ top: 0, behavior: 'smooth' });
          };
          pageNumbersContainer.appendChild(btn);
        }
      }

      document.dispatchEvent(new CustomEvent('filters:changed', { detail: { count: totalItems } }));
    }

    let debounceTimer: ReturnType<typeof setTimeout>;
    function debouncedApplyFilters(resetPage = false) {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        requestAnimationFrame(() => applyFilters(resetPage));
      }, 150);
    }

    inputs.forEach(input => {
      input.addEventListener('change', () => debouncedApplyFilters(true));
    });

    const globalSearch = document.getElementById('global-search');
    if (globalSearch) {
      globalSearch.addEventListener('input', () => debouncedApplyFilters(true));
    }
    
    if (pageSizeSelect) {
      pageSizeSelect.addEventListener('change', (e) => {
        itemsPerPage = parseInt((e.target as HTMLSelectElement).value, 10);
        debouncedApplyFilters(true);
      });
    }
    
    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        if (currentPage > 1) {
          currentPage--;
          applyFilters(false);
          window.scrollTo({ top: 0, behavior: 'smooth' });
        }
      });
    }
    
    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        currentPage++;
        applyFilters(false);
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }
    
    const clearSearchBtn = document.getElementById('clear-search');
    if (clearSearchBtn && globalSearch) {
      clearSearchBtn.addEventListener('click', () => {
        (globalSearch as HTMLInputElement).value = '';
        debouncedApplyFilters(true);
      });
    }

    if (clearBtn) {
      clearBtn.addEventListener('click', () => {
        inputs.forEach(input => {
          if (input.type === 'radio' || input.type === 'checkbox') input.checked = false;
        });
        if (globalSearch) (globalSearch as HTMLInputElement).value = '';
        debouncedApplyFilters(true);
      });
    }
    
    // Call on load to setup initial pagination
    applyFilters(true);
  });
</script>
