---
import type { TechEvent } from '../types';
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  event: TechEvent;
}

const { event } = Astro.props;
const { title, description, category, location, date, imageUrl, source, isLive, isFree, price } = event;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

---

<article class="event-card group relative bg-[var(--card-bg)] border border-[var(--border-color)] rounded-xl overflow-hidden hover:border-[var(--color-sim-brand)] hover:shadow-lg transition-all duration-300 flex flex-col h-full">
  
  <button 
    type="button" 
    class="open-modal-btn absolute inset-0 z-20 focus:outline-none focus:ring-2 focus:ring-[var(--color-sim-action)] rounded-lg cursor-pointer w-full h-full opacity-0" 
    aria-label={`${event.title}`}
    data-title={event.title}
    data-desc={event.description || 'Los detalles extendidos no se encuentran disponibles para este evento. Visite la página oficial mediante el botón de registro para obtener toda la información, cronogramas y requerimientos específicos.'}
    data-url={event.registrationUrl || event.url}
    data-image={event.imageUrl || ''}
    data-city={event.location.city}
    data-category={event.category}
    data-subcategory={event.subcategory || ''}
    data-price={event.isFree ? 'GRATIS' : (event.price || 'DE PAGO')}
    data-date={!isNaN(event.date.start.getTime()) ? event.date.start.toLocaleDateString('es-EC', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute:'2-digit' }) : 'Fecha por confirmar'}
  ></button>

  <!-- Image Section -->
  <div class="relative h-48 overflow-hidden bg-gray-100 dark:bg-gray-800 transition-colors duration-300">
    {event.imageUrl ? (
      <img 
        src={event.imageUrl} 
        alt={event.title} 
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
        loading="lazy"
        decoding="async"
        onerror="this.onerror=null; this.outerHTML='<div class=\\'w-full h-full flex flex-col items-center justify-center bg-gray-100 dark:bg-gray-800 transition-colors duration-300\\'><img src=\\'/loading_logo_dark.png\\' class=\\'w-24 h-auto opacity-20 block dark:hidden mb-2\\' alt=\\'SimCodec Logo\\' /><img src=\\'/loading_logo.png\\' class=\\'w-24 h-auto opacity-40 hidden dark:block mb-2\\' alt=\\'SimCodec Logo\\' /><span class=\\'text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest\\'>Sin Imagen Oficial</span></div>';"
      />
    ) : (
      <div class="w-full h-full flex flex-col items-center justify-center transition-colors duration-300">
        <img src="/loading_logo_dark.png" class="w-24 h-auto opacity-20 block dark:hidden mb-2" alt="SimCodec Logo" />
        <img src="/loading_logo.png" class="w-24 h-auto opacity-40 hidden dark:block mb-2" alt="SimCodec Logo" />
        <span class="text-[10px] font-bold text-gray-400 dark:text-gray-500 uppercase tracking-widest">Sin Imagen Oficial</span>
      </div>
    )}
    
    <div class="absolute top-3 inset-x-3 flex justify-between items-start gap-2 pointer-events-none">
      <!-- Izquierda: Etiqueta de Fecha o EN VIVO -->
      <div class="flex flex-wrap gap-2 flex-1 pointer-events-auto">
        {event.isLive ? (
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded bg-red-600 backdrop-blur-md border border-red-700 text-white text-[10px] font-bold tracking-wider uppercase shadow-md">
            <span class="w-1.5 h-1.5 rounded-full bg-white animate-pulse"></span>
            EN VIVO
          </span>
        ) : (
          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded bg-white/90 dark:bg-black/80 backdrop-blur-md border border-gray-300 dark:border-[var(--color-sim-brand)] text-gray-800 dark:text-white text-[10px] font-bold tracking-wider uppercase shadow-md line-clamp-1 max-w-[200px] sm:max-w-none text-left transition-colors duration-300">
            <svg class="w-3 h-3 text-[var(--color-sim-brand)] shrink-0 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
            <span class="truncate">{!isNaN(event.date.start.getTime()) ? event.date.start.toLocaleDateString('es-EC', { day: 'numeric', month: 'short', hour: '2-digit', minute:'2-digit' }) : 'TBD'}</span>
          </span>
        )}
      </div>

      <!-- Derecha: Etiqueta de Costo (Gratis / De Pago) -->
      <div class="flex flex-col gap-2 items-end shrink-0 pointer-events-auto">
        {event.isFree ? (
          <span class="inline-flex px-2 py-1 rounded border border-green-500 bg-white/90 dark:bg-black/80 backdrop-blur-md text-green-700 dark:text-green-400 text-[10px] font-bold uppercase tracking-wider shadow-md transition-colors duration-300">
            GRATIS
          </span>
        ) : (
          <span class="inline-flex px-2 py-1 rounded border border-orange-500 bg-white/90 dark:bg-black/80 backdrop-blur-md text-[var(--color-sim-orange)] text-[10px] font-bold uppercase tracking-wider font-mono shadow-md truncate max-w-[130px] transition-colors duration-300" title={event.price || 'DE PAGO'}>
            {event.price || 'DE PAGO'}
          </span>
        )}
      </div>
    </div>
  </div>

  <!-- Content Section -->
  <div class="flex flex-col flex-grow p-5 transition-colors duration-300">
    
    <div class="flex items-center gap-2 mb-3 text-xs font-mono text-[var(--color-sim-orange)] font-semibold uppercase tracking-wider transition-colors duration-300">
      <span>{event.category}</span>
      <span class="text-gray-400 dark:text-gray-600 font-bold transition-colors duration-300">•</span>
      <span class="text-gray-500 dark:text-gray-400 font-sans font-medium transition-colors duration-300">{event.source}</span>
    </div>

    <h3 class="text-lg font-bold text-[var(--text-color)] mb-2 line-clamp-2 leading-snug transition-colors duration-300">
      {event.title}
    </h3>
    
    <p class="text-sm text-gray-600 dark:text-gray-400 mb-4 line-clamp-2 leading-relaxed transition-colors duration-300">
      {event.description || 'Visite la página oficial del organizador para más detalles.'}
    </p>

    <!-- Meta Info Footer -->
    <div class="mt-auto pt-4 border-t border-[var(--border-color)] flex items-center justify-between transition-colors duration-300">
      <div class="flex items-center gap-1.5 text-xs font-medium text-gray-500 dark:text-gray-400 transition-colors duration-300">
        <svg class="w-4 h-4 text-[var(--color-sim-primary)] dark:text-gray-400 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
        {event.location.isVirtual ? 'Virtual / Online' : event.location.city}
      </div>
      
      <!-- Modal Trigger Button -->
      <button 
        class="open-modal-btn text-[var(--color-sim-action)] hover:text-blue-800 dark:hover:text-blue-400 p-1.5 rounded-md hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors pointer-events-none"
        aria-label="Ver detalles"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
      </button>
    </div>
  </div>
</article>

<style>
  .capitalize-first::first-letter {
    text-transform: capitalize;
  }
</style>

<!-- Schema.org JSON-LD para Eventos (SEO Rich Snippets) -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Event",
  "name": event.title,
  "description": event.description || "Evento tecnológico destacado.",
  "startDate": (event.date.start && !isNaN(event.date.start.getTime())) ? event.date.start.toISOString() : undefined,
  "endDate": (event.date.end && !isNaN(event.date.end.getTime())) ? event.date.end.toISOString() : undefined,
  "eventAttendanceMode": event.location.isVirtual ? "https://schema.org/OnlineEventAttendanceMode" : "https://schema.org/OfflineEventAttendanceMode",
  "eventStatus": "https://schema.org/EventScheduled",
  "location": event.location.isVirtual ? {
    "@type": "VirtualLocation",
    "url": event.registrationUrl || event.url
  } : {
    "@type": "Place",
    "name": event.location.city,
    "address": {
      "@type": "PostalAddress",
      "addressLocality": event.location.city,
      "addressCountry": "EC"
    }
  },
  "image": event.imageUrl ? [event.imageUrl] : [],
  "offers": {
    "@type": "Offer",
    "price": event.isFree ? "0" : "0",
    "priceCurrency": "USD",
    "url": event.registrationUrl || event.url,
    "availability": "https://schema.org/InStock"
  },
  "organizer": {
    "@type": "Organization",
    "name": event.source
  }
})}></script>
