---
import Layout from '../layouts/Layout.astro';
import { convex } from '../lib/convex';
import { api } from '../../convex/_generated/api';

const events = await convex.query(api.events.getAllEventsAdmin);
const logs = await convex.query(api.events.getAdminLogs);

// Ordenar eventos por fecha de inicio (del más cercano al más lejano)
const sortedEvents = [...events].sort((a, b) => a.dateStart - b.dateStart);

const validEvents = events.filter(e => e.isLinkValid).length;
const brokenEvents = events.length - validEvents;
const now = Date.now();
---

<Layout title="SimCodec | Admin Dashboard" description="Panel de control B2B para monitoreo de eventos y scrapers.">
  <div class="max-w-7xl mx-auto px-6 py-12 relative min-h-screen">
    
    <!-- Background Glow -->
    <div class="absolute top-[-10%] left-[-10%] w-96 h-96 bg-[var(--color-sim-brand)]/20 blur-[120px] rounded-full pointer-events-none"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-96 h-96 bg-[var(--color-sim-orange)]/10 blur-[120px] rounded-full pointer-events-none"></div>

    <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between mb-12 gap-6">
      <div>
        <h1 class="text-4xl font-black text-transparent bg-clip-text bg-gradient-to-r from-gray-900 to-gray-500 dark:from-white dark:to-gray-400 uppercase tracking-tight flex items-center gap-3 transition-all duration-300">
          <svg class="w-10 h-10 text-[var(--color-sim-brand)] transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
          System Control
        </h1>
        <p class="text-gray-600 dark:text-gray-400 mt-2 text-sm font-medium tracking-wide transition-colors duration-300">Monitorización avanzada de Data Scrapers y Eventos Tech</p>
      </div>
      <div class="flex gap-4">
        <!-- Stat Card 1 -->
        <div class="bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 backdrop-blur-md px-6 py-4 rounded-2xl flex flex-col items-end shadow-xl relative overflow-hidden group transition-colors duration-300">
          <div class="absolute inset-0 bg-gradient-to-br from-blue-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <span class="text-[10px] text-gray-500 dark:text-gray-400 font-bold uppercase tracking-[0.2em] relative z-10">Total Eventos</span>
          <span class="text-3xl font-black text-gray-900 dark:text-white relative z-10 font-mono mt-1">{events.length}</span>
        </div>
        <!-- Stat Card 2 -->
        <div class="bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 backdrop-blur-md px-6 py-4 rounded-2xl flex flex-col items-end shadow-xl relative overflow-hidden group transition-colors duration-300">
          <div class="absolute inset-0 bg-gradient-to-br from-red-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <span class="text-[10px] text-gray-500 dark:text-gray-400 font-bold uppercase tracking-[0.2em] relative z-10">Enlaces Rotos</span>
          <span class="text-3xl font-black text-red-600 dark:text-red-500 relative z-10 font-mono mt-1">{brokenEvents}</span>
        </div>
      </div>
    </div>

    <!-- Analytics & Telemetry Section -->
    <div class="mb-12 relative z-10">
      <h2 class="text-sm font-bold text-gray-600 dark:text-gray-400 uppercase tracking-[0.2em] mb-4 flex items-center gap-2">
        <svg class="w-4 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
        Data Mining & API Analytics
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        
        <div class="bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 backdrop-blur-xl p-5 rounded-2xl shadow-lg flex flex-col justify-between">
          <div class="flex justify-between items-start mb-4">
            <span class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest">Frecuencia Scraping</span>
            <span class="bg-emerald-100 dark:bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 text-[9px] px-2 py-0.5 rounded font-black uppercase">Activo</span>
          </div>
          <div>
            <div class="text-2xl font-black text-gray-900 dark:text-white font-mono">Cada 6 Horas</div>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Los robots buscan eventos nuevos 4 veces al día (Cron Job).</p>
          </div>
        </div>

        <div class="bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 backdrop-blur-xl p-5 rounded-2xl shadow-lg flex flex-col justify-between transition-colors duration-300">
          <div class="flex justify-between items-start mb-4">
            <span class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest">Fuentes Conectadas</span>
            <span class="bg-blue-100 dark:bg-blue-500/20 text-blue-600 dark:text-blue-400 text-[9px] px-2 py-0.5 rounded font-black uppercase">APIs & RSS</span>
          </div>
          <div>
            <div class="text-2xl font-black text-gray-900 dark:text-white font-mono">11 Endpoints</div>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1 truncate" title="Eventbrite, Meetup, Dev.to, Google News, CITEC, EPN, ESPOL, UCE, Devpost">Eventbrite, Meetup, Dev.to, CITEC, EPN...</p>
          </div>
        </div>

        <div class="bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 backdrop-blur-xl p-5 rounded-2xl shadow-lg flex flex-col justify-between">
          <div class="flex justify-between items-start mb-4">
            <span class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest">Volumen Peticiones</span>
            <span class="bg-purple-100 dark:bg-purple-500/20 text-purple-600 dark:text-purple-400 text-[9px] px-2 py-0.5 rounded font-black uppercase">Optimizado</span>
          </div>
          <div>
            <div class="text-2xl font-black text-gray-900 dark:text-white font-mono">~35 / ciclo</div>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Llamadas HTTP asíncronas para extraer datos de múltiples fuentes.</p>
          </div>
        </div>

        <div class="bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 backdrop-blur-xl p-5 rounded-2xl shadow-lg flex flex-col justify-between relative overflow-hidden">
          <div class="absolute inset-x-0 bottom-0 h-1 bg-gradient-to-r from-green-400 to-emerald-500"></div>
          <div class="flex justify-between items-start mb-4">
            <span class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-widest">Cuota de Red</span>
            <span class="bg-green-100 dark:bg-green-500/20 text-green-600 dark:text-green-400 text-[9px] px-2 py-0.5 rounded font-black uppercase">Ilimitado</span>
          </div>
          <div>
            <div class="text-2xl font-black text-gray-900 dark:text-white font-mono">100% Libre</div>
            <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Convex Serverless Actions sin límite estricto de web scraping.</p>
          </div>
        </div>

      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 relative z-10">
      
      <!-- Logs Section -->
      <div class="lg:col-span-4 flex flex-col">
        <h2 class="text-sm font-bold text-gray-600 dark:text-gray-400 uppercase tracking-[0.2em] mb-4 flex items-center gap-2 transition-colors duration-300">
          <svg class="w-4 h-4 text-[var(--color-sim-action)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          Cron Logs Recientes
        </h2>
        <div class="bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 backdrop-blur-xl rounded-2xl overflow-hidden h-[600px] flex flex-col shadow-2xl relative transition-colors duration-300">
          <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-transparent via-[var(--color-sim-action)] to-transparent opacity-50"></div>
          <div class="overflow-y-auto flex-1 p-5 space-y-4 custom-scrollbar" data-lenis-prevent>
            {logs.length > 0 ? logs.map(log => (
              <div class="bg-white dark:bg-black/20 rounded-xl p-4 border border-gray-200 dark:border-white/5 hover:border-gray-300 dark:hover:border-white/10 transition-colors duration-300">
                <div class="flex justify-between items-start mb-2">
                  <span class="text-xs font-bold text-gray-900 dark:text-white font-mono transition-colors duration-300">{log.taskName}</span>
                  <span class={`text-[9px] px-2 py-1 rounded font-black uppercase tracking-wider transition-colors duration-300 ${log.status === 'SUCCESS' ? 'bg-emerald-100 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border border-emerald-200 dark:border-emerald-500/20' : 'bg-red-100 dark:bg-red-500/10 text-red-600 dark:text-red-400 border border-red-200 dark:border-red-500/20'}`}>
                    {log.status}
                  </span>
                </div>
                <div class="flex items-center gap-2 text-[11px] text-gray-500 transition-colors duration-300 mb-3 font-mono">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  <span>Ejecutado: {new Date(log.executedAt).toLocaleString('es-EC', { dateStyle: 'short', timeStyle: 'medium' })}</span>
                </div>
                <div class="flex items-center gap-2 text-[11px] text-[var(--color-sim-brand)] transition-colors duration-300 mb-3 font-mono bg-[var(--color-sim-brand)]/10 px-2 py-1 rounded w-fit">
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  <span>Próximo Escaneo: {new Date(log.executedAt + 6 * 60 * 60 * 1000).toLocaleString('es-EC', { dateStyle: 'short', timeStyle: 'short' })}</span>
                </div>
                {log.eventsAdded !== undefined && (
                  <div class="text-[11px] text-gray-600 dark:text-gray-400 bg-gray-50 dark:bg-white/5 px-3 py-2 rounded-lg flex justify-between items-center border border-gray-100 dark:border-transparent mb-2">
                    <span>Eventos insertados:</span> 
                    <span class="font-bold text-gray-900 dark:text-white bg-[var(--color-sim-action)]/10 dark:bg-[var(--color-sim-action)]/20 px-2 py-0.5 rounded text-xs">{log.eventsAdded}</span>
                  </div>
                )}
                {log.details && (
                  <div class="text-[10px] text-gray-600 dark:text-gray-400 bg-blue-50/50 dark:bg-blue-900/10 px-3 py-2 rounded-lg border border-blue-100 dark:border-blue-800/30 whitespace-pre-line leading-relaxed font-mono">
                    {log.details}
                  </div>
                )}
                {log.errorMessage && (
                  <div class="text-[11px] text-orange-700 dark:text-orange-300 mt-2 bg-orange-50 dark:bg-orange-950/40 px-3 py-2 rounded-lg border border-orange-200 dark:border-orange-900/50 leading-relaxed">
                    {log.errorMessage}
                  </div>
                )}
              </div>
            )) : (
              <div class="flex flex-col items-center justify-center h-full text-center">
                <svg class="w-12 h-12 text-gray-400 dark:text-gray-600 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 002-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
                <p class="text-sm text-gray-500">No hay operaciones registradas en el sistema.</p>
              </div>
            )}
          </div>
        </div>
      </div>

      <!-- Events Table Section -->
      <div class="lg:col-span-8 flex flex-col">
        <h2 class="text-sm font-bold text-gray-600 dark:text-gray-400 uppercase tracking-[0.2em] mb-4 flex items-center gap-2 transition-colors duration-300">
          <svg class="w-4 h-4 text-blue-500 dark:text-blue-400 transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path></svg>
          Directorio Global de Eventos
        </h2>
        <div class="bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 backdrop-blur-xl rounded-2xl overflow-hidden h-[600px] flex flex-col shadow-2xl relative transition-colors duration-300">
          <div class="absolute top-0 inset-x-0 h-1 bg-gradient-to-r from-transparent via-blue-500 to-transparent opacity-50 z-20"></div>
          <div class="overflow-x-auto overflow-y-auto flex-1 custom-scrollbar" data-lenis-prevent>
            <table class="w-full text-left border-collapse whitespace-nowrap">
              <thead class="bg-gray-100/90 dark:bg-black/60 sticky top-0 backdrop-blur-md z-10 border-b border-gray-200 dark:border-white/10 transition-colors duration-300">
                <tr class="transition-colors duration-300">
                  <th class="p-5 text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-[0.2em] transition-colors duration-300">Estado</th>
                  <th class="p-5 text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-[0.2em] transition-colors duration-300">Título</th>
                  <th class="p-5 text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-[0.2em] transition-colors duration-300">Fuente</th>
                  <th class="p-5 text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-[0.2em] transition-colors duration-300">Fecha Inicio</th>
                  <th class="p-5 text-[10px] font-bold text-gray-500 dark:text-gray-400 uppercase tracking-[0.2em] text-right transition-colors duration-300">Registro</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 dark:divide-white/5 transition-colors duration-300">
                {sortedEvents.map(ev => {
                  const isNew = now - ev._creationTime < 24 * 60 * 60 * 1000;
                  return (
                  <tr class="hover:bg-black/[0.02] dark:hover:bg-white/[0.03] transition-colors duration-300 group">
                    <td class="p-5">
                      {ev.isLinkValid ? (
                        <div class="flex items-center gap-2 text-emerald-600 dark:text-emerald-400 text-xs font-medium">
                          <span class="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span>
                          Online
                        </div>
                      ) : (
                        <div class="flex items-center gap-2 text-red-600 dark:text-red-400 text-xs font-medium">
                          <span class="w-2 h-2 rounded-full bg-red-500 shadow-[0_0_8px_rgba(239,68,68,0.5)] animate-pulse"></span>
                          Offline
                        </div>
                      )}
                    </td>
                    <td class="p-5">
                      <div class="flex items-center gap-2">
                        <p class="text-sm font-semibold text-gray-900 dark:text-white max-w-[250px] truncate transition-colors duration-300" title={ev.title}>
                          {ev.title}
                        </p>
                        {isNew && (
                          <span class="px-1.5 py-0.5 rounded bg-[var(--color-sim-orange)] text-white text-[9px] font-black uppercase tracking-wider shadow-sm animate-pulse flex-shrink-0">
                            Nuevo
                          </span>
                        )}
                      </div>
                    </td>
                    <td class="p-5">
                      <span class="inline-flex px-2 py-1 bg-gray-100 dark:bg-white/5 rounded text-[10px] text-gray-600 dark:text-gray-300 font-mono uppercase tracking-wider border border-gray-200 dark:border-white/10 transition-colors duration-300">
                        {ev.source}
                      </span>
                    </td>
                    <td class="p-5 text-xs text-gray-600 dark:text-gray-400 font-medium transition-colors duration-300">
                      {new Date(ev.dateStart).toLocaleDateString('es-EC', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </td>
                    <td class="p-5 text-right">
                      <a href={ev.registrationUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center p-2 rounded-lg bg-blue-50 dark:bg-blue-500/10 text-blue-600 dark:text-blue-400 hover:bg-blue-100 dark:hover:bg-blue-500/20 transition-colors duration-300 border border-blue-200 dark:border-blue-500/20" title="Ver enlace de registro" aria-label={`Registrarse a ${ev.title}`}>
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
                      </a>
                    </td>
                  </tr>
                )})}
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>

<style>
  /* Custom Scrollbar for Admin Tables */
  .custom-scrollbar::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.2);
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: rgba(255, 255, 255, 0.2);
</style>
